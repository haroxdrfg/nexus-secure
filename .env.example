# ============================================================================
# NEXUS SECURE v2.2.0 - TRUE End-to-End Encrypted Messaging
# Environment Configuration Template
#
# ⚠️  PRODUCTION SECURITY CRITICAL ⚠️
# Copy this file to .env and customize with your secure values
# NEVER commit .env to git (already in .gitignore)
# ============================================================================

# ============ NODE & SERVER ============
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

# ============ HTTPS/TLS ============
# For development: Self-signed certificates auto-generated on startup
# For production: Use Let's Encrypt (free, auto-renews)
TLS_CERT_PATH=./certs/cert.crt
TLS_KEY_PATH=./certs/cert.key

# ============ DOMAIN & CORS ============
PRODUCTION_DOMAIN=nexus-secure-mess.com

# CORS allowed origins (comma-separated, NO SPACES, NO WILDCARDS for auth)
# Development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
# Production (example):
# ALLOWED_ORIGINS=https://nexus-secure-mess.com,https://www.nexus-secure-mess.com

# ============ SECURITY - CRYPTOGRAPHY ============

# JWT Secret (CHANGE THIS FOR PRODUCTION!)
# Generate secure 256-bit key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use:
#   openssl rand -hex 32
JWT_SECRET=CHANGE-ME-GENERATE-SECURE-256BIT-RANDOM-VALUE-IN-PRODUCTION

# Master Secret for HMAC audit logging (CHANGE THIS!)
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_SECRET=CHANGE-ME-GENERATE-SECURE-256BIT-RANDOM-VALUE-IN-PRODUCTION

# Message TTL (milliseconds) - when messages auto-expire
MESSAGE_TTL=120000

# ============ RATE LIMITING (DUAL LAYER) ============
# Must pass BOTH IP and Identity limits

# IP-based rate limit (distributed attack protection)
# 100 requests per minute maximum from any single IP
RATE_LIMIT_IP=100

# Identity-based rate limit (insider abuse protection)  
# 50 requests per minute maximum from any single user
RATE_LIMIT_IDENTITY=50

# ============ DATABASE & PERSISTENCE ============

# Database path (SQLite, will be created on first run)
DATABASE_PATH=./data/nexus-secure.db

# Audit log path (immutable, HMAC-protected)
AUDIT_LOG_PATH=./logs/audit.log

# ============ LOGGING & MONITORING ============

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path
LOG_FILE=./logs/server.log

# ============ E2E CRYPTOGRAPHY FEATURES ============

# Enable TRUE E2E encryption (server cannot decrypt)
E2E_ENABLED=true

# Enable forward secrecy (per-message unique keys)
FORWARD_SECRECY_ENABLED=true

# Enable audit logging (HMAC-protected tamper detection)
AUDIT_LOGGING_ENABLED=true

# Enable rate limiting
RATE_LIMITING_ENABLED=true

# ============ MAINTENANCE & BACKUP ============

# Auto-cleanup interval (milliseconds)
CLEANUP_INTERVAL=300000

# Backup enabled
BACKUP_ENABLED=true
BACKUP_PATH=./backups

# ============ DEVELOPMENT ONLY ============

# Development mode (more logging, auto-test users)
DEMO_MODE=false

# ============ DEPLOYMENT INSTRUCTIONS ============
# 
# 1. LOCAL DEVELOPMENT:
#    - Use defaults above
#    - Self-signed certs auto-generate
#    - Run: npm run dev
#
# 2. STAGING SERVER:
#    - Update ALLOWED_ORIGINS to staging domain
#    - Change JWT_SECRET and MASTER_SECRET
#    - Set NODE_ENV=production
#    - Setup HTTPS with Let's Encrypt or self-signed
#    - Run: npm start
#
# 3. PRODUCTION SERVER:
#    - Register domain (e.g., nexus-secure-production.com)
#    - Point DNS A record to server IP
#    - Setup HTTPS with Let's Encrypt:
#      sudo certbot --nginx -d nexus-secure-production.com
#    - Generate NEW JWT_SECRET (use openssl rand -hex 32)
#    - Generate NEW MASTER_SECRET (never reuse staging)
#    - Update ALLOWED_ORIGINS to production domain
#    - Setup daily backups of audit logs
#    - Monitor logs: tail -f ./logs/audit.log
#    - Deploy: npm start (or use PM2/systemd service)
#
# ============

# ============ CRITICAL SECURITY CHECKLIST ============
# 
# BEFORE PRODUCTION DEPLOYMENT:
#
# [ ] JWT_SECRET changed from default (openssl rand -hex 32)
# [ ] MASTER_SECRET changed from default (openssl rand -hex 32)
# [ ] Both secrets are unique per deployment (never reuse)
# [ ] ALLOWED_ORIGINS restricted to your domain ONLY
# [ ] NODE_ENV set to 'production'
# [ ] HTTPS certificates from Let's Encrypt (or valid CA)
# [ ] Database path on persistent storage (not /tmp)
# [ ] Audit logs path on persistent storage
# [ ] Backup strategy implemented (daily backup of audit.log)
# [ ] Firewall configured (only 80 and 443 exposed)
# [ ] SSH keys rotated
# [ ] Server OS patches applied
# [ ] Monitoring and alerting configured
# [ ] .env file has permissions 0600 (owner read-write only)
#
# ============
