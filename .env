# NEXUS SECURE v2 - Production Configuration
# ATTENTION: Changez le JWT_SECRET et ALLOWED_ORIGINS

NODE_ENV=production
PORT=3000

# Domaines autorisés
ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000

# JWT Secret - À générer de façon aléatoire!
# Générer: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_string_32_bytes_minimum

# SSL
SSL_KEY_PATH=./cert.key
SSL_CERT_PATH=./cert.crt

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW=60000
RATE_LIMIT_BLOCK_DURATION=900000

# Messages
MESSAGE_TTL=120000

# Audit
AUDIT_ENABLED=true
AUDIT_LOG_TO_FILE=true
